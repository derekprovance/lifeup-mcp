{
    "name": "lifeup-mcp-server",
    "version": "1.1.0",
    "description": "MCP Server for LifeUp Cloud API integration with Claude",
    "type": "module",
    "main": "build/index.js",
    "bin": {
        "lifeup-mcp": "build/index.js"
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --watch",
        "start": "node build/index.js",
        "dev": "tsx watch src/index.ts",
        "inspect": "node build/index.js",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "test:run": "vitest run",
        "test:e2e": "vitest run --config vitest.e2e.config.ts",
        "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
        "test:smoke": "node test-mcp.js",
        "test:all": "npm run test:run && npm run test:e2e",
        "test:safe-mode": "SAFE_MODE=true npm run test:e2e -- tests/e2e/suites/safe-mode.test.ts",
        "lint": "eslint src tests --ext .ts,.tsx",
        "lint:fix": "eslint src tests --ext .ts,.tsx --fix",
        "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
    },
    "keywords": [
        "mcp",
        "lifeup",
        "task-management",
        "claude"
    ],
    "author": "Derek Provance",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.26.0",
        "axios": "^1.13.5",
        "dotenv": "^17.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.2.3",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "eslint": "^9.0.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
